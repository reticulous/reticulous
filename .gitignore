# OS / editor
.DS_Store
._*

# Auto-generated artifacts (added by maintenance sweep)
__pycache__/
*.pyc
*.pyo

# Build artifacts (spangap-generated)
esp-idf/build/
esp-idf/sdkconfig
esp-idf/sdkconfig.old
esp-idf/staging/
esp-idf/managed_components/
web-interface/node_modules/
web-interface/dist/
web-interface/.quasar/

# Generated each build (browser straddle dispatcher)
web-interface/src/boot/*.gen.ts

# Generated each build: the spangap build wipes this dir and copies in every
# staged straddle's assets/lcd-icons/*.svg (this repo's own source of truth is
# assets/lcd-icons/). Which icons appear depends on the staged set, so
# tracking them just churns.
web-interface/src/app-icons/

# Generated each build (staged SPA bundle + build stamp baked into the data partition)
data/webroot/
data/build_times
